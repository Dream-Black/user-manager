# ============================================================
# AI Claw Desktop - 环境配置文件
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改 SERVER_URL 为你的公网服务器地址
# ============================================================

# 云端服务器地址（Electron 窗口加载的地址）
# 开发环境：通常使用 localhost:3000
# 生产环境：使用公网 IP 或域名，如 http://1.2.3.4
SERVER_URL=http://localhost:3000

# 开发环境标记（设为 development 时会打开 DevTools）
NODE_ENV=development
