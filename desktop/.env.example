# ============================================================
# AI Claw Desktop - 环境配置文件
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改 SERVER_URL 为你的公网服务器地址
# ============================================================

# 云端服务器地址（Electron 窗口加载的地址）
# 开发环境：通常使用 localhost:3000
# 生产环境：使用公网 IP 或域名，如 http://1.2.3.4
SERVER_URL=http://43.132.155.29

# 开发环境标记（设为 development 时会打开 DevTools）
NODE_ENV=development

# ============================================================
# Python Proxy 本地服务配置
# ============================================================

# 是否自动启动 Python Proxy（true/false）
# 设为 false 可以禁用自动启动
AUTO_START_PYTHON=true

# Python 可执行文件路径
# Windows: python 或 python3，或完整路径如 C:\Python39\python.exe
# macOS/Linux: python3 或 /usr/bin/python3
PYTHON_PATH=python

# Python Proxy 脚本路径（相对于 desktop 目录）
# 默认值: ../proxy/main.py
PYTHON_SCRIPT=C:/Users/22618/Desktop/AI Claw/proxy/main.py
